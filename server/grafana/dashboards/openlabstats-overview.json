      "options": {
        "orientation": "horizontal",
        "showValue": "always"
      },
      "title": "Installed Software Count by Device",
      "type": "barchart",
      "targets": [
        {
          "expr": "count by (hostname) (openlabstats_installed_software_info)",
          "legendFormat": "{{ hostname }}",
          "instant": true
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [{ "color": "green", "value": null }]
          },
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 36 },
      "id": 31,
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "name", "desc": false }],
        "footer": { "show": true, "reducer": ["count"] }
      },
      "title": "Software Inventory",
      "type": "table",
      "targets": [
        {
          "expr": "openlabstats_installed_software_info",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "Value": true,
              "instance": true,
              "job": true,
              "lab": true
            },
            "renameByName": {
              "hostname": "Device",
              "name": "Software",
              "publisher": "Publisher",
              "version": "Version"
            },
            "indexByName": {
              "name": 0,
              "version": 1,
              "publisher": 2,
              "hostname": 3
            }
          }
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 44 },
      "id": 104,
      "title": "Agent Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "custom": {
            "align": "center",
            "displayMode": "color-background-solid"
          }
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 45 },
      "id": 40,
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "instance", "desc": false }]
      },
      "title": "Agent Status",
      "type": "table",
      "targets": [
        {
          "expr": "up{job=\"openlabstats\"}",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true
            },
            "renameByName": {
              "instance": "Agent",
              "lab": "Lab",
              "Value": "Status"
            }
          }
        }
      ]
    }
