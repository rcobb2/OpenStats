      "options": {
        "orientation": "horizontal",
        "showValue": "always"
      },
      "title": "Usage by Lab/Room",
      "type": "barchart",
      "targets": [
        {
          "expr": "sum by (lab) (increase(openlabstats_app_usage_seconds_total[$__range]))",
          "legendFormat": "{{ lab }}",
          "instant": true
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "id": 21,
      "options": {
        "orientation": "horizontal",
        "showValue": "always"
      },
      "title": "Launches by Lab/Room",
      "type": "barchart",
      "targets": [
        {
          "expr": "sum by (lab) (increase(openlabstats_app_launches_total[$__range]))",
          "legendFormat": "{{ lab }}",
          "instant": true
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
